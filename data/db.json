            {
              "name": "home.html",
              "type": "file",
              "content": "\n              <div style=\"font-family: 'Inter', sans-serif; padding: 60px; color: #f8fafc; background: #020617; line-height: 1.6; min-height: 100%;\">\n                <header style=\"text-align: center; margin-bottom: 60px; position: relative;\">\n                  <div style=\"position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 300px; height: 300px; background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%); z-index: 0;\"></div>\n                  <h1 style=\"font-size: 4rem; margin: 0; font-weight: 800; letter-spacing: -0.05em; background: linear-gradient(to right, #60a5fa, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; position: relative; z-index: 1;\">GlassOS Pro</h1>\n                  <p style=\"color: #94a3b8; font-size: 1.25rem; font-weight: 500; margin-top: 10px; position: relative; z-index: 1;\">The Ultimate Collaborative Office Interface</p>\n                </header>\n                \n                <div style=\"display: grid; grid-template-columns: 1.5fr 1fr; gap: 32px; position: relative; z-index: 1;\">\n                  <div style=\"display: flex; flex-direction: column; gap: 32px;\">\n                    <section style=\"background: rgba(30, 41, 59, 0.5); padding: 32px; border-radius: 32px; border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px);\">\n                      <h2 style=\"font-size: 1.5rem; margin-top: 0; display: flex; align-items: center; gap: 12px; color: #60a5fa;\">\n                        <span style=\"display: block; width: 8px; height: 8px; border-radius: 50%; background: #60a5fa;\"></span>\n                        Core System Features\n                      </h2>\n                      <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 20px;\">\n                        <div>\n                          <h3 style=\"font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255, 255, 255, 0.3); margin-bottom: 8px;\">Network Backbone</h3>\n                          <ul style=\"padding-left: 0; list-style: none; font-size: 0.95rem;\">\n                            <li style=\"margin-bottom: 6px;\">🟢 mDNS Node Discovery</li>\n                            <li style=\"margin-bottom: 6px;\">🛡️ OAuth2 Security Handshake</li>\n                            <li style=\"margin-bottom: 6px;\">⚡ gRPC Service Bridge</li>\n                            <li>💬 XMPP Real-time Engine</li>\n                          </ul>\n                        </div>\n                        <div>\n                          <h3 style=\"font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255, 255, 255, 0.3); margin-bottom: 8px;\">Office Synergy</h3>\n                          <ul style=\"padding-left: 0; list-style: none; font-size: 0.95rem;\">\n                            <li style=\"margin-bottom: 6px;\">📂 Cross-App Data Sync</li>\n                            <li style=\"margin-bottom: 6px;\">📊 Relational DB Mapping</li>\n                            <li style=\"margin-bottom: 6px;\">📧 GlassMail Pro via gRPC</li>\n                            <li>🗓️ Calendar-to-Sheet Import</li>\n                          </ul>\n                        </div>\n                      </div>\n                    </section>\n\n                    <section style=\"background: rgba(30, 41, 59, 0.5); padding: 32px; border-radius: 32px; border: 1px solid rgba(255, 255, 255, 0.05); margin-top: 32px;\">\n                      <h2 style=\"font-size: 1.5rem; margin-top: 0; color: #a855f7;\">Recent System Updates</h2>\n                      <div style=\"font-size: 0.95rem; color: #94a3b8;\">\n                        <div style=\"padding: 12px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.05);\">\n                          <strong>Terminal Power:</strong> Full support for CLI arguments (ls -l, chmod 777, top -s).\n                        </div>\n                        <div style=\"padding: 12px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.05);\">\n                          <strong>Auth Backbone:</strong> Inter-node authorization now uses kernel-level OAuth2 grants.\n                        </div>\n                        <div style=\"padding: 12px 0;\">\n                          <strong>Database Engine:</strong> Migrated to a relational server model with specialized import triggers.\n                        </div>\n                      </div>\n                    </section>\n                  </div>\n\n                  <aside>\n                    <section style=\"background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(168, 85, 247, 0.1)); padding: 32px; border-radius: 32px; border: 1px solid rgba(255, 255, 255, 0.1);\">\n                      <h2 style=\"font-size: 1.25rem; margin-top: 0; color: white;\">Installed Software</h2>\n                      <div style=\"display: grid; grid-template-columns: 1fr; gap: 12px; margin-top: 20px;\">\n                        <div style=\"display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1;\"><div style=\"width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;\"></div>GlassMail Pro</div>\n                        <div style=\"display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1;\"><div style=\"width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;\"></div>Systems Messenger</div>\n                        <div style=\"display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1;\"><div style=\"width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;\"></div>Database Engine</div>\n                        <div style=\"display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1;\"><div style=\"width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;\"></div>Glass Sheets</div>\n                        <div style=\"display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1;\"><div style=\"width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;\"></div>Glass Calendar</div>\n                        <div style=\"display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1;\"><div style=\"width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;\"></div>Terminal v2.1</div>\n                        <div style=\"display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1;\"><div style=\"width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;\"></div>File Explorer</div>\n                        <div style=\"display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1;\"><div style=\"width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;\"></div>Print Manager</div>\n                        <div style=\"display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1;\"><div style=\"width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;\"></div>System Settings</div>\n                      </div>\n                    </section>\n                    \n                    <div style=\"margin-top: 32px; display: grid; grid-template-columns: 1fr; gap: 12px;\">\n                      <a href=\"local://home.html\" style=\"display: flex; align-items: center; justify-content: center; height: 50px; background: #3b82f6; color: white; border-radius: 16px; text-decoration: none; font-weight: 700; font-size: 0.9rem;\">Refresh Portal</a>\n                    </div>\n                  </aside>\n                </div>\n\n                <footer style=\"margin-top: 80px; text-align: center; color: #475569; font-size: 0.75rem; font-family: monospace; letter-spacing: 0.05em;\">\n                  NODE_ID: GLASS_WORKSTATION_001 • KERNEL: REACT_19_PROTO_X • PROTOCOLS: mDNS/OAuth2/XMPP/gRPC\n                </footer>\n              </div>\n            ",
